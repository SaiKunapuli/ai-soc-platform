# Wazuh Indexer (OpenSearch) — defaults for the single-node docker lab
AISOC_INDEXER_URL=https://localhost:9200
AISOC_INDEXER_USER=admin
AISOC_INDEXER_PASSWORD=changeme
# Lab uses self-signed certs; keep false only for the local lab
AISOC_INDEXER_VERIFY_CERTS=false

# Ollama (local, free LLM runtime)
AISOC_OLLAMA_URL=http://localhost:11434
# 7b for dev/iteration; set to qwen2.5:14b-instruct for the demo
AISOC_OLLAMA_MODEL=qwen2.5:7b-instruct
